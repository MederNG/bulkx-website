# Base URL for the upstream BULK Aura indexer API.
# The browser never calls this directly — it is only used server-side by the
# proxy route (/api/aura/[...]) , the wallet lookup fallback, and the offline
# `npm run fetch` script. Override it to point at a staging/mirror endpoint.
BULK_API_BASE=https://indexer.bulk.trade

# Vercel Cron backup for hourly TVL refresh (see vercel.json).
# CRON_SECRET — random string; Vercel sends it as Authorization: Bearer <CRON_SECRET>.
# GITHUB_DISPATCH_TOKEN — PAT with repo scope to POST repository_dispatch events.
CRON_SECRET=
GITHUB_DISPATCH_TOKEN=
